# Copia este archivo a .env y rellena los valores. .env no se sube al repositorio.

# Auth0 (social login)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
# En producción/preview: URL fija registrada en Auth0 (ej. https://tu-dominio.web.app/auth-callback).
# En local se ignora si contiene "localhost" y se usa window.location.origin/auth-callback.
VITE_AUTH0_REDIRECT_URI=

# Datos bancarios para instrucciones de pago (página de orden, paso 2).
# Se muestran al usuario solo tras hacer clic en "Ver datos bancarios".
# No incluyas aquí datos reales; usa tu .env local.
VITE_BANK_BENEFICIARY=Nombre del beneficiario
VITE_BANK_IBAN=MT00XXXX00000000000000000000000
VITE_BANK_NAME=Nombre del banco

# USDC Wallets
VITE_EXURY_USDC_WALLET_BSC=
VITE_EXURY_USDC_WALLET_SOL=
VITE_EXURY_USDC_WALLET_ETH=
VITE_EXURY_USDC_WALLET_POL=
VITE_EXURY_USDC_WALLET_ALGO=
VITE_EXURY_USDC_WALLET_AVAXC=

# BTC Wallets
VITE_EXURY_BTC_WALLET_BSC=
VITE_EXURY_BTC_WALLET_ETH=
VITE_EXURY_BTC_WALLET_SEGWIT=

# ETH Wallets
VITE_EXURY_ETH_WALLET_BSC=
VITE_EXURY_ETH_WALLET_ETH=
VITE_EXURY_ETH_WALLET_ARBITRUM=
VITE_EXURY_ETH_WALLET_BASE=

# BNB Wallets
VITE_EXURY_BNB_WALLET_BSC=